@model Vamino.Presentation.MVC.Areas.UserPanel.Models.DeleteLoanContractViewModel

@{
    ViewData["Title"] = "حذف قرارداد";
}

<div class="up-card">
    <div class="up-card-header d-flex justify-content-between align-items-center">
        <h5 class="up-card-title mb-0">حذف قرارداد</h5>
        <a class="btn btn-up"
           asp-area="UserPanel"
           asp-controller="LoanContracts"
           asp-action="Index">
            <i class="bi bi-arrow-right"></i> بازگشت
        </a>
    </div>

    <div class="up-card-body">
        <div class="alert alert-danger up-alert">
            <i class="bi bi-exclamation-triangle"></i>
            <div>
                <div class="fw-bold">آیا از حذف این قرارداد مطمئن هستید؟</div>
                <div class="small text-muted">این عملیات قابل بازگشت نیست.</div>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mt-3">
            <div class="up-card" style="box-shadow:none;">
                <div class="up-card-body">
                    <div class="row g-2">
                        <div class="col-md-4">
                            <div class="text-muted small">عنوان</div>
                            <div class="fw-bold">@Model.Title</div>
                        </div>

                        <div class="col-md-4">
                            <div class="text-muted small">مبلغ</div>
                            <div class="fw-bold">@Model.Amount.ToString("N0")</div>
                        </div>

                        <div class="col-md-4">
                            <div class="text-muted small">وضعیت</div>
                            <div>
                                <span class="up-badge warning">
                                    <span class="dot"></span>
                                    @Model.LoanStatus
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <form method="post"
              class="mt-3 d-flex gap-2 justify-content-end flex-wrap"
              asp-area="UserPanel"
              asp-controller="LoanContracts"
              asp-action="Delete">

            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-up danger">
                <i class="bi bi-trash3"></i> بله، حذف شود
            </button>

            <a class="btn btn-up"
               asp-area="UserPanel"
               asp-controller="LoanContracts"
               asp-action="Index">
                انصراف
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
