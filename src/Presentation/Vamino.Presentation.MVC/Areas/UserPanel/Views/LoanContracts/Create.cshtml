@{
    ViewData["Title"] = "ایجاد قرارداد جدید";
}

<div class="up-card">
    <div class="up-card-header">
        <h5 class="up-card-title mb-0">ایجاد قرارداد</h5>
        <a class="btn btn-up" asp-area="UserPanel" asp-controller="LoanContracts" asp-action="Index">
            <i class="bi bi-arrow-right"></i> بازگشت
        </a>
    </div>

    <div class="up-card-body">
        <form class="up-form" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">عنوان قرارداد</label>
                    <input class="form-control" placeholder="مثلاً وام خرید خودرو" />
                    <div class="up-help">عنوان واضح انتخاب کنید تا در مدیریت قراردادها راحت‌تر باشد.</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">مبلغ وام</label>
                    <input class="form-control" placeholder="مثلاً 250000000" />
                    <div class="up-help">حداقل ضامن‌ها بر اساس مبلغ محاسبه می‌شود.</div>
                </div>

                <div class="col-12">
                    <label class="form-label">توضیحات</label>
                    <textarea class="form-control" rows="4" placeholder="جزئیات قرارداد..."></textarea>
                </div>

                <div class="col-12 d-flex gap-2 justify-content-end flex-wrap mt-2">
                    <button type="submit" class="btn btn-up primary">
                        <i class="bi bi-check2-circle"></i> ثبت قرارداد
                    </button>
                    <a class="btn btn-up" asp-area="UserPanel" asp-controller="LoanContracts" asp-action="Index">
                        انصراف
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>