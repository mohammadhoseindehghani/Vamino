<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - پنل کاربری</title>

    <!-- Bootstrap RTL -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">

    <!-- Vazirmatn Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- UserPanel CSS -->
    <link href="~/userpanel/userpanel.css" rel="stylesheet" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body class="up-body">
    <div class="up-shell">
        <aside class="up-sidebar">
            @await Html.PartialAsync("~/Areas/UserPanel/Views/Shared/_Sidebar.cshtml")
        </aside>

        <main class="up-main">
            <header class="up-topbar">
                @await Html.PartialAsync("~/Areas/UserPanel/Views/Shared/_Topbar.cshtml")
            </header>

            <section class="up-content">
                <div class="up-content-inner">
                    @await Html.PartialAsync("~/Areas/UserPanel/Views/Shared/_Toast.cshtml")

                    @RenderBody()
                </div>
            </section>

            <footer class="up-footer">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="text-muted small">سیستم مدیریت قراردادهای وام</div>
                    <div class="text-muted small">© @DateTime.Now.Year</div>
                </div>
            </footer>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
