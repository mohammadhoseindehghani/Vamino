@model IEnumerable<dynamic>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "مدیریت کاربران";
}

<div class="ap-filter-box">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label fw-bold">جستجو</label>
            <input type="text" class="form-control" placeholder="نام، کد ملی، شماره تماس..." />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">وضعیت</label>
            <select class="form-select">
                <option>همه</option>
                <option>فعال</option>
                <option>غیرفعال</option>
            </select>
        </div>
        <div class="col-md-5 d-flex align-items-end justify-content-md-end gap-2">
            <button class="btn btn-ap primary">
                <i class="bi bi-search me-1"></i>
                جستجو
            </button>
            <button class="btn btn-ap">
                <i class="bi bi-arrow-clockwise me-1"></i>
                بازنشانی
            </button>
            <button class="btn btn-ap success" disabled>
                <i class="bi bi-person-plus me-1"></i>
                افزودن کاربر
            </button>
        </div>
    </div>
</div>

<div class="ap-card">
    <div class="ap-card-header">
        <h5 class="ap-card-title">لیست کاربران</h5>
        <span class="text-muted small">فقط نمایش - عملیات فعلاً غیرفعال است</span>
    </div>
    <div class="ap-card-body table-responsive">
        <table class="table ap-table align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>نام و نام خانوادگی</th>
                    <th>کد ملی</th>
                    <th>شماره تماس</th>
                    <th>ایمیل</th>
                    <th>وضعیت</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>محمد حسینی</td>
                    <td>0012345678</td>
                    <td>09121234567</td>
                    <td>m.hosseini@mail.com</td>
                    <td>
                        <span class="ap-badge success">
                            <span class="dot"></span>
                            فعال
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <button class="btn btn-ap" disabled>
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-ap warning" disabled>
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn btn-ap danger" disabled>
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td>2</td>
                    <td>زهرا کریمی</td>
                    <td>0098765432</td>
                    <td>09129876543</td>
                    <td>z.karimi@mail.com</td>
                    <td>
                        <span class="ap-badge info">
                            <span class="dot"></span>
                            ثبت‌شده
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <button class="btn btn-ap" disabled>
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-ap warning" disabled>
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn btn-ap danger" disabled>
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td>3</td>
                    <td>علی رضایی</td>
                    <td>1122334455</td>
                    <td>09351234567</td>
                    <td>a.rezaei@mail.com</td>
                    <td>
                        <span class="ap-badge warning">
                            <span class="dot"></span>
                            در انتظار
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <button class="btn btn-ap" disabled>
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-ap warning" disabled>
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn btn-ap danger" disabled>
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
