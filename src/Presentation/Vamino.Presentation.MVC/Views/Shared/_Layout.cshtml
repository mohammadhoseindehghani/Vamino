<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - وامینو</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-4 sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cash-stack me-2"></i> وامینو
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="نمایش منو">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> خانه
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-file-earmark-lock me-1"></i> حریم خصوصی
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#about-section">
                                <i class="bi bi-info-circle me-1"></i> درباره ما
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i> حساب کاربری
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-area="UserPanel" asp-controller="LoanContracts" asp-action="Index">
                                            <i class="bi bi-person-vcard me-2"></i> پنل کاربری
                                        </a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-area="Auth" asp-controller="Auth" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> خروج
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-area="Auth" asp-controller="Auth" asp-action="Login" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-box-arrow-in-right me-1"></i> ورود
                            </a>
                            <a asp-area="Auth" asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-sm">
                                <i class="bi bi-person-plus me-1"></i> ثبت‌نام
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3 mt-4 bg-white">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - وامینو -
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">حریم خصوصی</a>
            <span class="mx-2">|</span>
            <a href="#about-section" class="text-decoration-none">درباره ما</a>
            <span class="mx-2">|</span>
            <a href="#how-it-works" class="text-decoration-none">مراحل</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
